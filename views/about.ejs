<%- include('partials/head') %>
<main class="main">
  <section class="page-hero">
    <div class="container container--narrow">
      <h1 class="page-title">About Me</h1>
    </div>
  </section>
  <div class="container container--narrow prose page-body">
    <div class="about-card">
      <div class="about-avatar"><span><%= settings.blog_author.split(' ').map(n=>n[0]).slice(0,2).join('') %></span></div>
      <div class="about-info">
        <h2><%= settings.blog_author %></h2>
        <p class="about-tagline"><%= settings.blog_tagline %></p>
      </div>
    </div>
    <div class="about-text">
      <%- settings.blog_about.replace(/\n\n/g,'</p><p>').replace(/\n/g,'<br>') %>
    </div>
    <div class="about-links">
      <a href="/contact" class="btn-primary">Get in Touch →</a>
    </div>
  </div>
</main>
<%- include('partials/footer') %>
